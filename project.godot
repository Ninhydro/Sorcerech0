; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Sorcerech"
config/version="0.2"
run/main_scene="res://scenes/ui/MainMenu.tscn"
config/features=PackedStringArray("4.2", "GL Compatibility")
config/icon="res://assets_image/Sorcerech_Fini_small.png"

[autoload]

Dialogic="*res://addons/dialogic/Core/DialogicGameHandler.gd"
TransitionManager="*res://scenes/world/transition_manager.tscn"
Global="*res://config/Global.gd"
SaveLoadManager="*res://config/SaveLoadManager.gd"
MemoryManager="*res://config/memory_manager.gd"
Cartographer="*res://scripts/UI/Cartographer.gd"
LoadingScreen="*res://scenes/ui/loadingscreen.tscn"

[dialogic]

